{
  "agency_topology": {
    "default_tier": "L0",
    "escalation_policy": "sequential_chain",
    "max_parse_retries": 2,
    "providers": {
      "L0_thinker": {
        "engine": "llama_cpp",
        "model": "deepseek-r1:8b",
        "endpoint": "http://localhost:11434/v1",
        "capabilities": [
          "reasoning",
          "lean4",
          "chat"
        ]
      },
      "L0_typist": {
        "engine": "llama_cpp",
        "model": "qwen2.5-coder:latest",
        "endpoint": "http://localhost:11434/v1",
        "capabilities": ["bash", "file_edit", "python"]
      },
      "L1_micro": {
        "engine": "gemini",
        "model": "gemini-3.1-flash-lite-preview",
        "api_env_var": "GEMINI_API_KEY",
        "fallback_for": [
          "L0_thinker",
          "L0_typist"
        ]
      },
      "L2_standard": {
        "engine": "gemini",
        "model": "gemini-3-flash-preview",
        "api_key": "YOUR_API_KEY_HERE_OR_USE_API_ENV_VAR",
        "fallback_for": [
          "L1_micro"
        ]
      },
      "L3_complex": {
        "engine": "gemini",
        "model": "gemini-2.5-pro",
        "api_env_var": "GEMINI_API_KEY",
        "fallback_for": [
          "L2_standard"
        ]
      },
      "L4_frontier": {
        "engine": "gemini",
        "model": "gemini-3.1-pro-preview",
        "api_env_var": "GEMINI_API_KEY",
        "fallback_for": [
          "L3_complex"
        ]
      }
    }
  }
}
